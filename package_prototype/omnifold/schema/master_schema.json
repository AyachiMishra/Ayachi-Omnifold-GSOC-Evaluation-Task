{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OmniFold Master Dataset Schema",
  "type": "object",
  "required": ["metadata_version", "weights", "observables", "nn_model"],
  "properties": {
    "metadata_version": { "type": "string" },
    
    "weights": {
      "$ref": "weights.json"
    },
    
    "observables": {
      "$ref": "observables.json"
    },
    
    "nn_model": {
      "$ref": "nn_model.json"
    }
  }
}