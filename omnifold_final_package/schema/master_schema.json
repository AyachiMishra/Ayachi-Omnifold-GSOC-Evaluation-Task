{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OmniFold Master Dataset Schema",
  "purpose":"referencing all other schemas",
  "type": "object",
  "required": ["metadata", "weights", "observables", "nn_model"],
  "properties": {
    "metadata": { "$ref":"metadata_schema.json" },
    
    "weights": {
      "$ref": "weights_schema.json"
    },
    
    "observables": {
      "$ref": "observables_schema.json"
    },
    
    "nn_model": {
      "$ref": "nn_model_schema.json"
    }
  }
}